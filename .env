# Firebase Admin SDK
# Path to your serviceAccountKey.json (downloaded from Firebase console)
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey.json
FIREBASE_STORAGE_BUCKET=teleleprosy.firebasestorage.app

# Zoom Meeting SDK (Server-to-Server OAuth or Meeting SDK)
ZOOM_SDK_KEY=your_zoom_sdk_key
ZOOM_SDK_SECRET=your_zoom_sdk_secret

# CORS
FRONTEND_ORIGIN=https://tele-lepra-frontend.vercel.app

# WhatsApp Cloud API (Meta) — leave blank to keep WA dispatch disabled.
# WA_TOKEN: a permanent System User token with the
#   `whatsapp_business_messaging` + `whatsapp_business_management` scopes.
# WA_PHONE_ID: the Phone Number ID shown on the WhatsApp panel in
#   developers.facebook.com (NOT the actual phone number).
WA_TOKEN=
WA_PHONE_ID=
WA_TPL_APPOINTMENT=appointment_scheduled
WA_TPL_DECISION=triage_decision
WA_TPL_RULEOUT=triage_decision
WA_LANG=en
