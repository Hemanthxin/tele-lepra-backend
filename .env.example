# Copy to .env for local development. In production (Render) set these in
# the Dashboard → Environment, NOT in this file.

# ---- Firebase Admin SDK ----
# LOCAL: leave the JSON envs blank and point this at your downloaded file.
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey.json
# RENDER / VERCEL / any cloud: paste the entire serviceAccountKey.json
# contents here as one line (escape inner double-quotes), OR use the
# base64-encoded form below. The loader prefers env vars over the file path.
FIREBASE_CREDENTIALS_JSON=
FIREBASE_CREDENTIALS_B64=
FIREBASE_STORAGE_BUCKET=teleleprosy.firebasestorage.app

# ---- Zoom Server-to-Server OAuth (REQUIRED for real meeting creation) ----
# Create a "Server-to-Server OAuth" app at https://marketplace.zoom.us/develop
# Scopes needed: meeting:write:meeting:admin (or meeting:write for user-level)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ---- Zoom Meeting SDK (OPTIONAL — only for in-app Zoom embed) ----
# Create a separate "Meeting SDK" app type if you embed Zoom in the browser
# instead of opening join_url in a new tab.
ZOOM_SDK_KEY=
ZOOM_SDK_SECRET=

# ---- CORS ----
# Comma-separated allow-list. Add the Vercel prod URL + any custom domain.
# Vercel preview URLs (*.vercel.app) are matched by an internal regex —
# you don't need to list them here.
FRONTEND_ORIGIN=http://localhost:5173

# ---- WhatsApp Cloud API (Meta) ----
WA_TOKEN=
WA_PHONE_ID=
WA_TPL_APPOINTMENT=appointment_scheduled
WA_TPL_DECISION=triage_decision
WA_TPL_RULEOUT=triage_decision
WA_LANG=en
